{
  "targets": {
    "huawei": {
      "description": "Example Huawei Cloud Ubuntu target. Copy this file to deploy/targets.local.json and edit values.",
      "ssh": "root@YOUR_HUAWEI_PUBLIC_IP",
      "site_dir": "/home/snh48_web",
      "branch": "main",
      "repo_url": "git@github.com:MINGG2333/snh48_web.git",
      "transcript_repo_url": "git@github.com:MINGG2333/transcript_analyze.git",
      "service_name": "snh48-huawei",
      "restart": "systemctl restart snh48-huawei",
      "status": "systemctl is-active --quiet snh48-huawei",
      "local_url": "http://127.0.0.1:8000/timeline",
      "public_base_url": "https://your-domain.example",
      "public_urls": [
        "https://your-domain.example/",
        "https://your-domain.example/timeline",
        "https://your-domain.example/static/js/main.js",
        "https://your-domain.example/static/js/timeline.js",
        "https://your-domain.example/api/timeline/schedule",
        "https://your-domain.example/api/qa/status",
        "https://your-domain.example/image-proxy/health"
      ],
      "nginx": {
        "mode": "generated",
        "remote_path": "/etc/nginx/conf.d/your-domain.example.conf",
        "server_names": [
          "your-domain.example",
          "www.your-domain.example"
        ],
        "ssl_certificate": "/etc/letsencrypt/live/your-domain.example/fullchain.pem",
        "ssl_certificate_key": "/etc/letsencrypt/live/your-domain.example/privkey.pem",
        "image_proxy_upstream": "http://127.0.0.1:8899/",
        "image_proxy_cache_keys_zone_size": "32m",
        "image_proxy_cache_max_size": "3g",
        "access_log": "/var/log/nginx/snh48_huawei_access.log",
        "error_log": "/var/log/nginx/snh48_huawei_error.log"
      },
      "deploy_by_default": false
    }
  }
}
