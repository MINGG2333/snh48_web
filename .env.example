# ── AI 问答密码（必填，否则该功能将被禁用） ──────────────────────────
# 访问者需要输入此密码才能使用 AI 问答功能，保护你的 API 额度不被耗尽
SITE_PASSWORD=

# ── 背景词管理密码（必填，否则该功能将被禁用） ──────────────────────
# 管理首页滚动背景词需要此密码（与 AI 问答密码相互独立）
# 如不需要管理背景词，可留空以禁用此功能
SCROLLER_PASSWORD=

# ── 观察页管理密码（建议设置，否则观察页将被禁用） ─────────────────
# 观察页用于管理员查看用户使用情况，与 SITE_PASSWORD / SCROLLER_PASSWORD 相互独立
OB_PASSWORD=xxxxxxxxx

# ── 礼物回复页管理密码（建议设置，否则礼物回复页 API 将被禁用） ─────
# 礼物回复页使用独立密码，与 OB_PASSWORD 相互独立
GIFT_REPLIES_PASSWORD=xxxxxxxxx

# ── 房间消息页管理密码（可选） ─────────────────────────────────────
# 留空时默认复用 GIFT_REPLIES_PASSWORD
ROOM_MESSAGES_PASSWORD=

# ── 计分礼物页管理密码（可选） ─────────────────────────────────────
# 留空时默认复用 GIFT_REPLIES_PASSWORD
SCORE_GIFTS_PASSWORD=

# ── 记忆页访问与确认密码（建议设置，否则记忆页 API 将被禁用） ─────
# 普通访问/提交密码。页面用于记录粉丝和陈嘉仪之间的记忆，不做排名。
MEMORIES_VIEW_PASSWORD=xxxxxxxxx
# 应援会模式密码：可审核待处理记忆，并标记“应援会确认”
MEMORIES_FANCLUB_PASSWORD=xxxxxxxxx
# 本人模式密码：可标记“本人确认”
MEMORIES_IDOL_PASSWORD=xxxxxxxxx

# ── DeepSeek API（问答系统必须） ─────────────────────────────────────
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ── 生产运行安全配置 ─────────────────────────────────────────────────
# 生产环境使用已提交的 js-dist/css-dist；修改源 JS/CSS 后需先运行 node script/obfuscate_js.cjs
USE_OBFUSCATED_JS=true

# 生产环境只监听本机，由 Nginx 反向代理；不要在域名/HTTPS 可用后监听公网 0.0.0.0
HOST=127.0.0.1
PORT=8000

# HTTPS 生产环境启用 Secure Cookie。只有 IP:8000/http 临时测试时才改为 false
SECURE_COOKIES=true

# 默认只信任本机 Nginx 传来的 X-Real-IP / X-Forwarded-For
# Docker、CLB、CDN 或多层反代时，只把实际连接后端的代理 IP/CIDR 加进来
TRUSTED_PROXY_PEERS=127.0.0.1,::1

# ── 防滥用配置（可选覆盖） ─────────────
# 按需修改以下值。注意：不要在等号后面写 # 注释，否则解析器会把注释也读进去
# 每 IP 每 60 秒最多提问数
QA_RATE_LIMIT_PER_WINDOW=10
# 时间窗口（秒）
QA_RATE_LIMIT_WINDOW_SECONDS=300
# 同一用户两次提问的最小间隔（秒）
QA_USER_COOLDOWN_SECONDS=30
# 每用户每日最大提问次数
QA_DAILY_QUOTA_PER_USER=20
# 每 IP 每天最多提问次数（持久化，重启不丢失）
QA_DAILY_IP_QUOTA=5
# 每用户同时处理的最大任务数
QA_MAX_CONCURRENT_PER_USER=2
# 默认在服务启动时后台预热 QA 知识库；冷启动调试管理页时可临时设为 false
QA_WARMUP_ON_STARTUP=true
# 每 IP 每 300 秒最多密码尝试次数
PASSWORD_RATE_LIMIT_PER_WINDOW=5
# 密码尝试时间窗口（秒）
PASSWORD_RATE_LIMIT_WINDOW_SECONDS=3000
# 余额接口成功结果缓存（秒）
BALANCE_CACHE_SECONDS=300
# 每 IP 每窗口最多余额查询次数
BALANCE_MAX_PER_WINDOW=10
# 余额查询限速窗口（秒）
BALANCE_WINDOW_SECONDS=60
# 每 IP 每窗口最多 OB 密码失败尝试次数
OB_LOGIN_MAX_PER_WINDOW=10
# OB 密码失败尝试限速窗口（秒）
OB_LOGIN_WINDOW_SECONDS=300

# ── 可选覆盖 ──────────────────────────────────────────────────────────
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-v4-flash
# SITE_TITLE=心上珍藏集           # 网站标题
# SITE_DESCRIPTION=记录 SNH48陈嘉仪 的公开信息，提供基于 LLM 的 AI 问答  # 网站描述
# ICP 备案号
SITE_ICP=京ICP备2026026973号
# 公安联网备案号
SITE_POLICE_ICP=京公网安备11010602202601号
# 备案号中的数字部分（用于链接）
SITE_POLICE_ICP_CODE=11010602202601
# 网站域名
SITE_DOMAIN=cjy.plus

# ── 时光轴直播汇总路径（可选覆盖） ────────────────────────────────
# live_push_replay_matcher.py 生成的 summary.csv 所在目录（含回放信息）
# 服务器上实际路径：/home/snh48-fan-hub/live_push_replays/
LIVE_PUSH_REPLAY_ROOT=/home/snh48-fan-hub/live_push_replays

# ── 礼物回复数据目录（可选覆盖） ───────────────────────────────────
# gift_reply_exporter.py 生成的 gifts.csv / summary.json 所在目录
# 服务器上实际路径：/home/snh48-fan-hub/room_record/陈嘉仪_161808449/gift_replies/
GIFT_REPLIES_DIR=/home/snh48-fan-hub/room_record/陈嘉仪_161808449/gift_replies

# ── 房间完整消息 CSV（可选覆盖） ───────────────────────────────────
# room_monitor.py 生成的 messages.csv。完整原始消息仅建议在腾讯云数据源服务器读取。
ROOM_MESSAGES_CSV_PATH=/home/snh48-fan-hub/room_record/陈嘉仪_161808449/messages.csv
# 房间语音转录 JSONL。这里只同步派生小文本，不同步语音原文件。
ROOM_AUDIO_TRANSCRIPTS_PATH=/home/snh48-fan-hub/room_record/陈嘉仪_161808449/audio_transcripts/room_audio_transcripts.jsonl
# 房间消息页“忽略未回礼物批次”的运行状态文件。该文件不由 Git 跟踪。
ROOM_MESSAGES_IGNORE_PATH=/home/snh48_web/website/data/room_messages_ignored_batches.json
# 优先使用两台网站服务器之间的 SSH 直连同步；开启后按钮操作不再等待 GitHub。
# 腾讯云可设 ROOM_MESSAGES_IGNORE_DIRECT_PEER=root@8.210.188.184
# 阿里云可设 ROOM_MESSAGES_IGNORE_DIRECT_PEER=root@124.222.72.203
ROOM_MESSAGES_IGNORE_DIRECT_SYNC=false
ROOM_MESSAGES_IGNORE_DIRECT_PEER=
ROOM_MESSAGES_IGNORE_DIRECT_PATH=/home/snh48_web/website/data/room_messages_ignored_batches.json
ROOM_MESSAGES_IGNORE_DIRECT_CONNECT_TIMEOUT_SECONDS=3
ROOM_MESSAGES_IGNORE_DIRECT_TIMEOUT_SECONDS=10
# 不再默认通过 GitHub 同步房间消息忽略状态；多服务器生产环境优先配置直连同步。
ROOM_MESSAGES_IGNORE_GIT_SYNC=false
ROOM_MESSAGES_IGNORE_GIT_REMOTE=origin
ROOM_MESSAGES_IGNORE_GIT_BRANCH=main
ROOM_MESSAGES_IGNORE_GIT_RETRIES=2
ROOM_MESSAGES_IGNORE_GIT_TIMEOUT_SECONDS=30
ROOM_MESSAGES_REFRESH_INTERVAL_SECONDS=60

# ── 计分礼物 JSON（可选覆盖） ─────────────────────────────────────
# score_gift_exporter.py 生成的派生小数据。
SCORE_GIFTS_DATA_PATH=/home/snh48-fan-hub/room_record/陈嘉仪_161808449/score_gifts/score_gifts.json

# ── 记忆页运行数据（可选覆盖） ─────────────────────────────────────
# 真实 memories.json 是运行数据，不由 Git 跟踪。腾讯云建议作为写入源；阿里云作为副本展示时可关闭提交。
MEMORIES_DATA_PATH=/home/snh48_web/website/data/memories/memories.json
MEMORIES_START_DATE=2025-09-01
MEMORIES_SUBMIT_ENABLED=true
MEMORIES_SUBMIT_MAX_PER_WINDOW=5
MEMORIES_SUBMIT_WINDOW_SECONDS=600

# ── 远程弹幕兜底安全配置（可选覆盖） ───────────────────────────────
# 本地弹幕文件优先；远程 danmu_url 仅作兜底。默认不强制域名白名单，先避免历史弹幕误伤。
DANMU_REMOTE_TIMEOUT_SECONDS=15
DANMU_REMOTE_MAX_BYTES=20971520
# 逗号分隔；为空表示只拦截内网/localhost/非 http(s)，不按域名拦截
DANMU_REMOTE_ALLOWED_HOSTS=
DANMU_REMOTE_ENFORCE_HOST_ALLOWLIST=false
# 留空则默认写入 LIVE_PUSH_REPLAY_ROOT/陈嘉仪_161808449/.danmu_url_cache
DANMU_REMOTE_CACHE_DIR=

# ── 行程表 CSV 路径（可选覆盖） ─────────────────────────────────────
# schedule_monitor.py 生成的 schedule.csv 路径
# 服务器上实际路径：/home/snh48-fan-hub/schedule_record/schedule.csv
SCHEDULE_CSV_PATH=/home/snh48-fan-hub/schedule_record/schedule.csv

# ── 出道整百天庆祝 ───────────────────────────────────────────────────
# 第300天基准日期；此后每100天自动新增永久飘屏和永久时光轴事件。
DEBUT_300_DATE=2026-07-31
# 仅用于未公开环境预演第300天动画和飘屏；正式环境保持为空。
DEBUT_300_TEST_DATE=
DEBUT_MILESTONE_INTERVAL_DAYS=100
# 里程碑当天至之后第7天（含）展示动画，共8个自然日。
DEBUT_CELEBRATION_DAYS_AFTER=7
