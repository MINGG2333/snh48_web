# ── AI 问答密码（必填，否则该功能将被禁用） ──────────────────────────
# 访问者需要输入此密码才能使用 AI 问答功能，保护你的 API 额度不被耗尽
SITE_PASSWORD=

# ── 背景词管理密码（必填，否则该功能将被禁用） ──────────────────────
# 管理首页滚动背景词需要此密码（与 AI 问答密码相互独立）
# 如不需要管理背景词，可留空以禁用此功能
SCROLLER_PASSWORD=

# ── DeepSeek API（问答系统必须） ─────────────────────────────────────
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ── 防滥用配置（可选覆盖） ─────────────
# 按需修改以下值。注意：不要在等号后面写 # 注释，否则解析器会把注释也读进去
# 每 IP 每 60 秒最多提问数
QA_RATE_LIMIT_PER_WINDOW=10
# 时间窗口（秒）
QA_RATE_LIMIT_WINDOW_SECONDS=300
# 同一用户两次提问的最小间隔（秒）
QA_USER_COOLDOWN_SECONDS=30
# 每用户每日最大提问次数
QA_DAILY_QUOTA_PER_USER=20
# 每 IP 每天最多提问次数（持久化，重启不丢失）
QA_DAILY_IP_QUOTA=5
# 每用户同时处理的最大任务数
QA_MAX_CONCURRENT_PER_USER=2
# 每 IP 每 300 秒最多密码尝试次数
PASSWORD_RATE_LIMIT_PER_WINDOW=5
# 密码尝试时间窗口（秒）
PASSWORD_RATE_LIMIT_WINDOW_SECONDS=3000

# ── 可选覆盖 ──────────────────────────────────────────────────────────
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-v4-flash
# HOST=0.0.0.0
# PORT=8000
# SITE_TITLE=心上珍藏集           # 网站标题
# SITE_DESCRIPTION=记录 SNH48陈嘉仪 的公开信息，提供基于 LLM 的 AI 问答  # 网站描述
# ICP 备案号
SITE_ICP=京ICP备2026026973号
# 公安联网备案号
SITE_POLICE_ICP=京公网安备11010602202601号
# 备案号中的数字部分（用于链接）
SITE_POLICE_ICP_CODE=11010602202601
# 网站域名
SITE_DOMAIN=cjy.plus

# ── 时光轴直播汇总路径（可选覆盖） ────────────────────────────────
# live_push_replay_matcher.py 生成的 summary.csv 所在目录（含回放信息）
# 服务器上实际路径：/home/snh48-fan-hub/live_push_replays/
LIVE_PUSH_REPLAY_ROOT=/home/snh48-fan-hub/live_push_replays

# ── 行程表 CSV 路径（可选覆盖） ─────────────────────────────────────
# schedule_monitor.py 生成的 schedule.csv 路径
# 服务器上实际路径：/home/snh48-fan-hub/schedule_record/schedule.csv
SCHEDULE_CSV_PATH=/home/snh48-fan-hub/schedule_record/schedule.csv
