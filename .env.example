# ── 网站密码 ──────────────────────────────────────────────────────────
# 访问者需要输入此密码才能使用 AI 问答功能，保护你的 API 额度不被耗尽
SITE_PASSWORD=xxxxxxxxx

# ── DeepSeek API（问答系统必须） ─────────────────────────────────────
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ── 可选覆盖 ──────────────────────────────────────────────────────────
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-v4-flash
# HOST=0.0.0.0
# PORT=8000
